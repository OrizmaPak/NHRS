APP_ENV=development
DOMAIN=localhost
NHRS_IMAGE_TAG=v1.0.0

# Shared infrastructure
REDIS_URL=redis://redis:6379
JWT_SECRET=<generate-secure-value>
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
AUTH_API_BASE_URL=http://auth-api:8081
RBAC_API_BASE_URL=http://rbac-service:8090
AUDIT_API_BASE_URL=http://audit-log-service:8091
PROFILE_API_BASE_URL=http://user-profile-service:8092
MEMBERSHIP_API_BASE_URL=http://membership-service:8103
NOTIFICATION_API_BASE_URL=http://notification-service:8101
