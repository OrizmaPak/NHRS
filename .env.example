CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Service ports
GATEWAY_PORT=8080
AUTH_API_PORT=8081
OTP_PORT=8082
SESSION_PORT=8083
TOKEN_PORT=8084
NIN_LINK_PORT=8085
RBAC_PORT=8090
AUDIT_LOG_PORT=8091
USER_PROFILE_PORT=8092
ORGANIZATION_PORT=8093
DOCTOR_REGISTRY_PORT=8094
NOTIFICATION_PORT=8101
FILE_DOCUMENT_PORT=8102
MEMBERSHIP_PORT=8103
HEALTH_RECORDS_INDEX_PORT=8104
CLINICAL_ENCOUNTER_PORT=8105
LAB_RESULT_PORT=8106
PHARMACY_DISPENSE_PORT=8107
EMERGENCY_INVENTORY_PORT=8108
TASKFORCE_DIRECTORY_PORT=8109
CASE_PORT=8110
UI_THEME_PORT=8111

# Cluster URIs (Option 2: same value; Option 3: split by domain)
IDENTITY_MONGODB_URI=mongodb+srv://orizma:<db_password>@nodeexpress.h8jrpv8.mongodb.net/?appName=NodeExpress
GOVERNANCE_MONGODB_URI=mongodb+srv://orizma:<db_password>@nodeexpress.h8jrpv8.mongodb.net/?appName=NodeExpress
HEALTHDATA_MONGODB_URI=mongodb+srv://orizma:<db_password>@nodeexpress.h8jrpv8.mongodb.net/?appName=NodeExpress
SUPPORT_MONGODB_URI=mongodb+srv://orizma:<db_password>@nodeexpress.h8jrpv8.mongodb.net/?appName=NodeExpress
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Optional explicit DB names for scripts/tools
AUTH_DB_NAME=nhrs_auth_db
OTP_DB_NAME=nhrs_otp_db
SESSION_DB_NAME=nhrs_session_db
TOKEN_DB_NAME=nhrs_token_db
