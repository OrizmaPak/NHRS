APP_ENV=development
DOMAIN=localhost

# Shared infrastructure
REDIS_URL=redis://redis:6379
JWT_SECRET=<change-me>

# Service ports
GATEWAY_PORT=8080
AUTH_API_PORT=8081
OTP_PORT=8082
SESSION_PORT=8083
TOKEN_PORT=8084
NIN_LINK_PORT=8085
RBAC_PORT=8090
AUDIT_LOG_PORT=8091
USER_PROFILE_PORT=8092
ORGANIZATION_PORT=8093
DOCTOR_REGISTRY_PORT=8094
HEALTH_RECORDS_PORT=8095
ENCOUNTER_NOTES_PORT=8096
LAB_PORT=8097
PHARMACY_PORT=8098
EMERGENCY_REQUESTS_PORT=8099
CATALOG_PORT=8100
NOTIFICATION_PORT=8101
FILE_DOCUMENT_PORT=8102

# Cluster URIs (Option 2: same value; Option 3: split by domain)
IDENTITY_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=NHRS
GOVERNANCE_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=NHRS
HEALTHDATA_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=NHRS
SUPPORT_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=NHRS
