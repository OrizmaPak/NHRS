TASKFORCE_DIRECTORY_API_BASE_URL=http://taskforce-directory-service:8109
CASE_API_BASE_URL=http://case-service:8110
DOCTOR_REGISTRY_API_BASE_URL=http://doctor-registry-service:8094
UI_THEME_API_BASE_URL=http://ui-theme-service:8111
